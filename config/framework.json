  ],
  "templates": [
    "RequirementAnalysis",
    "TechnicalDesign",
    "RiskAnalysis",
    "ApiDocumentation",
    "ChangeSummary",
    "ReleaseNote",
    "ExistingLogicAnalysis",
    "ProjectContext"
  ],
  "orchestrator": {
    "cachePolicy": "Orchestrator/CachePolicy.md",
    "projectScanPolicy": "Orchestrator/ProjectScanPolicy.md",
    "routingPolicy": "Orchestrator/RoutingPolicy.md",
    "shortcutCommands": "Orchestrator/ShortcutCommands.md",
    "roleSelectionPolicy": "Orchestrator/RoleSelectionPolicy.md"
  },
  "pluginSupport": {
    "codex": {
      "manifest": ".codex-plugin/plugin.json",
      "skills": "skills/"
    },
    "qoder": {
      "manifest": ".qoder-plugin/plugin.json",
      "rules": ".qoder/rules/enterprise-ai-framework.md",
      "skills": "skills/"
    }
  },
  "shortcutCommands": {
    "INIT": {
      "workflow": "ContextInitialization",
      "skills": [
        "enterprise-ai-framework"
      ],
      "modifyCode": false
    },
    "API_DOC": {
      "workflow": "ApiDevelopment",
      "skills": [
        "ApiDocumentation",
        "ExistingLogicAnalysis"
      ],
      "modifyCode": false
    },
    "LOGIC": {
      "workflow": "ExistingLogicConfirmation",
      "skills": [
        "ExistingLogicAnalysis"
      ],
      "modifyCode": false
    },
    "BUG": {
      "workflow": "BugFix",
      "skills": [
        "Debugging",
        "RiskAnalysis",
        "ChangeSummary"
      ],
      "modifyCode": "depends-on-user-request"
    },
    "FEATURE": {
      "workflow": "FeatureDevelopment",
      "skills": [
        "RequirementAnalysis",
        "TechnicalDesign",
        "RiskAnalysis",
        "TaskBreakdown",
        "CodeGeneration",
        "UnitTesting",
        "CodeReview",
        "ChangeSummary"
      ],
      "modifyCode": true
    },
    "REVIEW": {
      "workflow": "CodeReview",
      "skills": [
        "CodeReview"
      ],
      "modifyCode": false
    },
    "FRONTEND": {
      "workflow": "FrontendImplementation",
      "skills": [
        "ExistingLogicAnalysis",
        "FrontendImplementation",
        "CodeReview",
        "ChangeSummary"
      ],
      "modifyCode": "depends-on-user-request"
    },
    "SQL_REVIEW": {
      "workflow": "DatabaseMigration",
      "skills": [
        "RiskAnalysis",
        "DatabaseDesign"
      ],
      "modifyCode": false
    },
    "PROJECT_SCAN": {
      "workflow": "ProjectScan",
      "skills": [
        "ProjectContext"
      ],
      "modifyCode": false
    }
  },
  "runtimeDetection": {
    "php": [
      "composer.json",
      "composer.lock",
      "Dockerfile",
      "docker-compose.yml"
    ],
    "thinkphp": [
      "ThinkPHP/ThinkPHP.php",
      "vendor/topthink/framework",
      "think",
      "application"
    ],
    "frontend": [
      "package.json",
      "webpack.config.js",
      "vite.config.js",
      "public",
      "assets",
      "static",
      "src"
    ]
  },
  "todo": [
